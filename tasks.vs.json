{
  "version": "0.2.1",
  "tasks": [
    {
      "taskLabel": "Build",
      "appliesTo": "/",
      "type": "launch",
      "command": "${workspaceRoot}\\build_env.bat",
      "args": [ "${env.TT_BUILD_ARCH}", "all" ],
      "inheritEnvironments": [ "${cpp.activeConfiguration}" ],
      "contextType": "build"
    },
    {
      "taskLabel": "Clean",
      "appliesTo": "/",
      "type": "launch",
      "command": "${workspaceRoot}\\build_env.bat",
      "args": [ "${env.TT_BUILD_ARCH}", "clean" ],
      "inheritEnvironments": [ "${cpp.activeConfiguration}" ],
      "contextType": "clean"
    },
    {
      "taskLabel": "Install x86+x64",
      "appliesTo": "/",
      "type": "launch",
      "command": "${workspaceRoot}\\install_vs.bat",
      "args": [],
      "contextType": "custom"
    }
  ]
}
